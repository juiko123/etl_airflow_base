# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno para el stack ETL + Airflow
# Copia este archivo a .env y ajusta los valores antes de ejecutar
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Airflow core ──────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW_IMAGE_NAME=etl_airflow_base-airflow   # nombre de la imagen construida localmente

# Clave de cifrado para metadatos sensibles (Fernet key de 32 bytes en base64)
# Genera una con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=CHANGE_ME_generate_with_python_fernet

# Usuario administrador inicial de Airflow UI
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

# ── Base de datos de metadatos de Airflow ─────────────────────────────────────
AIRFLOW_METADATA_USER=airflow
AIRFLOW_METADATA_PASSWORD=airflow
AIRFLOW_METADATA_DB=airflow

# ── Fuente Oracle ─────────────────────────────────────────────────────────────
SOURCE_DIALECT=oracle
SOURCE_HOST=oracle            # nombre del servicio Docker
SOURCE_PORT=1521
SOURCE_DATABASE=FREEPDB1
SOURCE_USER=etl_user
SOURCE_PASSWORD=secret
SOURCE_POOL_SIZE=3

# ── Destino PostgreSQL (ETL) ──────────────────────────────────────────────────
TARGET_HOST=postgres          # nombre del servicio Docker
TARGET_PORT=5432
TARGET_DATABASE=testdb
TARGET_USER=etl
TARGET_PASSWORD=secret
TARGET_POOL_SIZE=5

# ── Parámetros de ejecución del ETL ──────────────────────────────────────────
ETL_CHUNK_SIZE=10000
ETL_MAX_WORKERS=4
ETL_RETRY_ATTEMPTS=5
